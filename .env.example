# Keep this file public. Put actual values only in your host's encrypted environment settings.
# Checkout cannot go live until every required value has been verified.
LIVE_CHECKOUT_ENABLED=false
STRIPE_CHECKOUT_MODE=live
STRIPE_SECRET_KEY=
PUBLIC_BASE_URL=https://your-domain.example
PUBLIC_STOREFRONT_ORIGIN=https://emerickchasse.github.io
PAWSWIPE_PRODUCT_NAME=
PAWSWIPE_PRODUCT_DESCRIPTION=
PAWSWIPE_SKU=
PAWSWIPE_UNIT_AMOUNT_CENTS=
PAWSWIPE_SHIPPING_RATE_CENTS=
PAWSWIPE_DELIVERY_MIN_BUSINESS_DAYS=
PAWSWIPE_DELIVERY_MAX_BUSINESS_DAYS=
PAWSWIPE_ALLOWED_COUNTRIES=

# Stripe Tax must be configured with accurate registrations before enabling live checkout.
STRIPE_AUTOMATIC_TAX_ENABLED=false
STRIPE_WEBHOOK_SECRET=

# Printful Orders API. Keep the token encrypted and scoped to store 18458606.
# false creates an idempotent draft; true submits and charges the merchant billing method.
PRINTFUL_API_TOKEN=
PRINTFUL_STORE_ID=18458606
PRINTFUL_VARIANT_S=6a53ef4031cc29
PRINTFUL_VARIANT_M=6a53ef4031cc68
PRINTFUL_VARIANT_L=6a53ef4031cc81
PRINTFUL_AUTO_CONFIRM=false

# Human approvals default closed. Set each true only from direct evidence for that exact gate.
PAWSWIPE_SAMPLE_APPROVED=false
PAWSWIPE_SUPPLIER_BILLING_APPROVED=false
PAWSWIPE_CUSTOMER_POLICIES_APPROVED=false
PAWSWIPE_PRIVATE_SUPPORT_APPROVED=false
